PORT=5001
CORS_ORIGIN=http://localhost:8081

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mobile
DB_LOG=false

# Chỉ bật trong môi trường development
DB_SYNC=true
DB_SYNC_ALTER=true

# Seeder demo
RUN_SEEDERS=true
SEED_USER_PASSWORD=your_seed_password

# JWT & Cookie
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL_MS=1209600000

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# SMTP Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="Golden Spoons"

# SePay / VietQR
SEPAY_SECRET=your_sepay_secret
SEPAY_BANK_CODE=MB
SEPAY_ACCOUNT_NO=your_bank_account
SEPAY_ACCOUNT_NAME="Your Bank Account Name"